# =============================================================================
# Nexus MVP — переменные окружения
# Скопируйте в .env и заполните своими значениями
# =============================================================================

# ─── LLM (обязательно) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Если используете прокси (например, api.manus.im):
# OPENAI_BASE_URL=https://api.manus.im/api/llm-proxy/v1/

# ─── База данных ─────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:nexus@localhost:5433/nexus

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# ─── MinIO (S3-совместимое хранилище) ────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── Транскрипция ────────────────────────────────────────────────────────────
# api — использует OpenAI Whisper API (рекомендуется)
# local — использует faster-whisper локально (требует GPU/много RAM)
WHISPER_MODE=api

# ─── Опционально ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=  # если хотите использовать Google Gemini вместо OpenAI
# HF_TOKEN=        # для приватных моделей HuggingFace
